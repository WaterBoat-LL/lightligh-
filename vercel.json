{
  "version": 2,
  "public": true,
  "rewrites": [
    { "source": "/", "destination": "/blogs/index.html" },
    { "source": "/view", "destination": "/blogs/view.html" },
    { "source": "/((?!api/).*)", "destination": "/blogs/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
